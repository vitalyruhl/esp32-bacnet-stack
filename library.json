{
  "name": "ESP32 BACnet Stack",
  "version": "0.35.0",
  "keywords": "bacnet, bacnet-ip, bacnet-client, bacnet-stack, building-automation, bms, automation, hvac, scada, esp32, arduino, platformio, ethernet, wifi, cpp, portable, windows, winsock, cmake",
  "description": "Portable BACnet/IP client core and read-only ESP32 server demo for Arduino and native Windows applications.",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/vitalyruhl/esp32-bacnet-stack.git"
  },
  "authors": [
    {
      "name": "Vitaly Ruhl",
      "email": "info@vitaly-ruhl.de"
    }
  ],
  "frameworks": [
    "arduino"
  ],
  "platforms": [
    "espressif32"
  ],
  "headers": [
    "BacnetClient.h",
    "BacnetServer.h",
    "ArduinoBacnetClient.h",
    "ArduinoBacnetServer.h",
    "ArduinoEspBacnet.h",
    "EspBacnet.h"
  ],
  "build": {
    "srcFilter": "+<*> -<main.cpp> -<platform/windows/>"
  },
  "export": {
    "include": [
      "src/**",
      "examples/**",
      "docs/**",
      "tools/**",
      "README.md",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "library.json"
    ],
    "exclude": [
      ".git",
      ".git/**",
      ".pio",
      ".pio/**",
      "**/.pio",
      "**/.pio/**",
      "**/.pioenvs",
      "**/.pioenvs/**",
      "**/.piolibdeps",
      "**/.piolibdeps/**",
      ".Temp",
      ".Temp/**",
      "**/.Temp",
      "**/.Temp/**",
      ".vscode",
      ".vscode/**",
      ".idea",
      ".idea/**",
      "*.code-workspace",
      "tools/native/build",
      "tools/native/build/**",
      "tools/portable-smoke/build",
      "tools/portable-smoke/build/**",
      "src/main.cpp",
      "**/secret/secrets.h",
      "**/secret/wifiSecret.h",
      "**/secrets.h",
      "**/wifiSecret.h",
      "**/settings.local.ps1"
    ]
  }
}
